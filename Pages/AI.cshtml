@page
@model RubberJointsAI.Pages.AIModel
@{
    Layout = "_Layout";
    ViewData["HideUserBar"] = true;
}

<style>
    /* Prevent body/html scrolling on AI page — everything stays in fixed containers */
    html, body { overflow: hidden !important; height: 100% !important; }
</style>

<div class="ai-container">
    <!-- Side Panel (conversation history) -->
    <div class="ai-sidebar" id="aiSidebar">
        <div class="ai-sidebar-header">
            <span class="ai-sidebar-title">Chats</span>
            <button class="ai-sidebar-close" id="closeSidebar">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <line x1="18" y1="6" x2="6" y2="18"></line>
                    <line x1="6" y1="6" x2="18" y2="18"></line>
                </svg>
            </button>
        </div>
        <button class="ai-new-chat" id="newChatBtn">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <line x1="12" y1="5" x2="12" y2="19"></line>
                <line x1="5" y1="12" x2="19" y2="12"></line>
            </svg>
            New Chat
        </button>
        <div class="ai-chat-list" id="chatList">
        </div>
    </div>

    <!-- Overlay for mobile sidebar -->
    <div class="ai-overlay" id="aiOverlay"></div>

    <!-- Main Chat Area -->
    <div class="ai-main">
        <!-- Combined topbar + status in one row -->
        @{
            int progressPct = Model.TotalWeeks > 0 ? (int)((Model.Week - 1) * 100.0 / Model.TotalWeeks) : 0;
            if (progressPct > 100) progressPct = 100;
        }
        <div class="ai-topbar-combined">
            <button class="ai-menu-btn" id="openSidebar">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <line x1="3" y1="6" x2="21" y2="6"></line>
                    <line x1="3" y1="12" x2="21" y2="12"></line>
                    <line x1="3" y1="18" x2="21" y2="18"></line>
                </svg>
            </button>
            <div class="ai-topbar-center">
                <span class="ai-topbar-week">Week @Model.Week of @Model.TotalWeeks</span>
                <div class="ai-topbar-bar"><div class="ai-topbar-fill" style="width:@(progressPct)%"></div></div>
            </div>
            <div class="ai-status-banner-phase">@Model.Phase</div>
        </div>

        <!-- START TRAINING — fixed right below the status bar -->
        <a href="/Index" class="ai-start-training-btn">
            🔥 START TRAINING 💪
        </a>

        <!-- Messages area (scrollable) — joke, info, messages, and chips all scroll -->
        <div class="ai-messages" id="aiMessages">

            <!-- Joke card — scrolls with messages -->
            <div class="ai-joke-card ai-joke-in-scroll" id="jokeCard">
                <div class="ai-joke-icon">😂</div>
                <div class="ai-joke-text" id="jokeText"></div>
                <div class="ai-joke-tagline">— Your joints, probably</div>
            </div>

            <!-- Today's Quick Glance — compact 2-line summary -->
            <div class="ai-info-card ai-info-compact">
                <div class="ai-info-nugget" id="aiStatsLine">💪 Loading today's stats...</div>
                <div class="ai-info-nugget">📊 Check <strong>Progress</strong> tab to track your journey</div>
            </div>

            <!-- AI intro -->
            <div class="ai-message ai-message-assistant">
                <div class="ai-avatar">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M12 2L9 7l-5 1 3.5 3.5L7 17l5-2.5L17 17l-.5-5.5L20 8l-5-1z"></path>
                    </svg>
                </div>
                <div class="ai-bubble ai-bubble-assistant">
                    <p>Ask me anything about your program, exercises, or supplements!</p>
                </div>
            </div>

        </div>

        <!-- FIXED BOTTOM: chips + input + disclaimer — never scrolls -->
        <div class="ai-bottom-fixed">
            <div class="ai-suggestions-fixed" id="aiSuggestions">
                <button class="ai-chip" data-prompt="Give me a status update on where I am in my program — what week, what I've completed today, and how my overall progress looks.">
                    My status
                </button>
                <button class="ai-chip" data-prompt="What should I focus on in today's session? Any tips for getting the most out of my exercises?">
                    Today's focus
                </button>
                <button class="ai-chip" data-prompt="How is my progress this week compared to what's expected? Am I on track?">
                    Weekly progress
                </button>
            </div>
            <div class="ai-input-wrapper">
                <textarea class="ai-input" id="aiInput" placeholder="Ask your AI coach..." rows="1"></textarea>
                <button class="ai-send-btn" id="aiSendBtn" disabled>
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <line x1="22" y1="2" x2="11" y2="13"></line>
                        <polygon points="22 2 15 22 11 13 2 9 22 2"></polygon>
                    </svg>
                </button>
            </div>
            <div class="ai-disclaimer-slim">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                    <path d="M10.29 3.86L1.82 18a2 2 0 001.71 3h16.94a2 2 0 001.71-3L13.71 3.86a2 2 0 00-3.42 0z"></path>
                    <line x1="12" y1="9" x2="12" y2="13"></line>
                    <line x1="12" y1="17" x2="12.01" y2="17"></line>
                </svg>
                <span><strong>Not medical advice.</strong> Always consult a professional.</span>
            </div>
        </div>
    </div>
</div>

<script>
