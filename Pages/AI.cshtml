    ];

    let jokeIndex = Math.floor(Math.random() * jokes.length);

    function showNewJoke() {
        jokeIndex = (jokeIndex + 1) % jokes.length;
        const jokeText = document.getElementById('jokeText');
        if (jokeText) {
            jokeText.style.opacity = '0';
            setTimeout(() => {
                jokeText.textContent = '"' + jokes[jokeIndex] + '"';
                jokeText.style.opacity = '1';
            }, 200);
        }
    }

    // Show a random joke on page load
    document.getElementById('jokeText').textContent = '"' + jokes[jokeIndex] + '"';

    // === Sidebar Toggle ===
    const sidebar = document.getElementById('aiSidebar');
    const overlay = document.getElementById('aiOverlay');
    const openBtn = document.getElementById('openSidebar');
    const closeBtn = document.getElementById('closeSidebar');

    function openSidebar() {
        sidebar.classList.add('open');
        overlay.classList.add('visible');
    }
    function closeSidebar() {
        sidebar.classList.remove('open');
        overlay.classList.remove('visible');
    }

    openBtn.addEventListener('click', openSidebar);
    closeBtn.addEventListener('click', closeSidebar);
    overlay.addEventListener('click', closeSidebar);

    // === Auto-resize textarea ===
    const input = document.getElementById('aiInput');
    const sendBtn = document.getElementById('aiSendBtn');

    input.addEventListener('input', function() {
        this.style.height = 'auto';
        this.style.height = Math.min(this.scrollHeight, 120) + 'px';
        sendBtn.disabled = this.value.trim().length === 0;
    });

    // === Send message — calls real AI backend ===
    let isSending = false;

    async function sendMessage() {
        const text = input.value.trim();
        if (!text || isSending) return;
        isSending = true;

        // Rotate joke on every message
        showNewJoke();

        const messagesDiv = document.getElementById('aiMessages');

        // Add user bubble
        const userMsg = document.createElement('div');
        userMsg.className = 'ai-message ai-message-user';
        userMsg.innerHTML = `<div class="ai-bubble ai-bubble-user">${escapeHtml(text)}</div>`;
        messagesDiv.appendChild(userMsg);

        // Clear input
        input.value = '';
        input.style.height = 'auto';
        sendBtn.disabled = true;

        // Add AI thinking bubble
        const aiMsg = document.createElement('div');
        aiMsg.className = 'ai-message ai-message-assistant';
        aiMsg.innerHTML = `
            <div class="ai-avatar">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M12 2L9 7l-5 1 3.5 3.5L7 17l5-2.5L17 17l-.5-5.5L20 8l-5-1z"></path>
                </svg>
            </div>
            <div class="ai-bubble ai-bubble-assistant">
                <div class="ai-typing"><span></span><span></span><span></span></div>
            </div>`;
        messagesDiv.appendChild(aiMsg);
        messagesDiv.scrollTop = messagesDiv.scrollHeight;

        try {
            const resp = await fetch('/api/ai/chat', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ message: text })
            });

            const data = await resp.json();
            const bubble = aiMsg.querySelector('.ai-bubble-assistant');

            if (data.success && data.response) {
                bubble.innerHTML = formatResponse(data.response);
            } else {
                bubble.innerHTML = `<p style="color:var(--red);">Sorry, I couldn't process that. ${data.error || 'Please try again.'}</p>`;
            }
        } catch (err) {
            const bubble = aiMsg.querySelector('.ai-bubble-assistant');
            bubble.innerHTML = `<p style="color:var(--red);">Connection error. Please check your internet and try again.</p>`;
        }

        messagesDiv.scrollTop = messagesDiv.scrollHeight;
        isSending = false;
    }

    // Format AI response text into HTML
    function formatResponse(text) {
        text = text.replace(/\*\*(.*?)\*\*/g, '<strong>$1</strong>');
        const paragraphs = text.split('\n\n').filter(p => p.trim());
        if (paragraphs.length > 1) {
            return paragraphs.map(p => `<p>${p.replace(/\n/g, '<br>')}</p>`).join('');
        }
        return `<p>${text.replace(/\n/g, '<br>')}</p>`;
    }

    sendBtn.addEventListener('click', sendMessage);
    input.addEventListener('keydown', function(e) {
        if (e.key === 'Enter' && !e.shiftKey) {
            e.preventDefault();
            sendMessage();
        }
    });

    // === Quick suggestion chips — trigger real AI call ===
    document.querySelectorAll('.ai-chip').forEach(chip => {
        chip.addEventListener('click', function() {
            input.value = this.dataset.prompt;
            input.dispatchEvent(new Event('input'));
            sendMessage();
        });
    });

    // === New Chat ===
    document.getElementById('newChatBtn').addEventListener('click', function() {
        const messagesDiv = document.getElementById('aiMessages');
        // Keep the info card and AI intro (first 2 children)
        while (messagesDiv.children.length > 2) {
            messagesDiv.removeChild(messagesDiv.lastChild);
        }
        showNewJoke();
        closeSidebar();
        addChatToList('New conversation');
    });

    // === Chat list ===
    let chatCount = 0;
    function addChatToList(title) {
        chatCount++;
        const chatList = document.getElementById('chatList');
        const item = document.createElement('div');
        item.className = 'ai-chat-item active';
        chatList.querySelectorAll('.ai-chat-item').forEach(el => el.classList.remove('active'));
        const now = new Date();
        const time = now.toLocaleTimeString([], {hour: '2-digit', minute: '2-digit'});
        item.innerHTML = `
            <div class="ai-chat-item-title">${title}</div>
            <div class="ai-chat-item-time">${time}</div>`;
        chatList.prepend(item);
    }
    addChatToList('New session');

    function escapeHtml(text) {
        const div = document.createElement('div');
        div.textContent = text;
        return div.innerHTML;
    }

    // === Auto-send prompt from query parameter (e.g., from "Ask AI" buttons on Today page) ===
    (function() {
        const params = new URLSearchParams(window.location.search);
        const autoPrompt = params.get('prompt');
        if (autoPrompt && autoPrompt.trim()) {
            // Clean up the URL so refreshing doesn't re-send
            window.history.replaceState({}, '', '/AI');
            // Set the input and send after a short delay to let page initialize
            setTimeout(() => {
                input.value = autoPrompt.trim();
                input.dispatchEvent(new Event('input'));
                sendMessage();
            }, 300);
        }
    })();

    // === Load today's stats (exercise/supplement counts) in background ===
    fetch('/api/ai-stats', { credentials: 'same-origin' })
        .then(r => r.json())
        .then(d => {
            if (d.success) {
                const el = document.getElementById('aiStatsLine');
                if (el) el.textContent = '💪 ' + d.exercisesDone + '/' + d.exercisesTotal + ' exercises · ' + d.supplementsDone + '/' + d.supplementsTotal + ' supplements';
            }
        })
        .catch(() => {
            const el = document.getElementById('aiStatsLine');
            if (el) el.textContent = '💪 Check Today tab for your progress';
        });

    // === Prefetch Today page data in background to warm server cache ===
    fetch('/api/today-prefetch', { credentials: 'same-origin' }).catch(() => {});

    // === Mobile Safari viewport fix: use real visible height ===
    function setRealHeight() {
        const navBar = 56; // bottom nav height
        const h = window.innerHeight - navBar;
        document.querySelector('.ai-container').style.height = h + 'px';
        document.querySelector('.ai-main').style.height = h + 'px';
    }
    setRealHeight();
    window.addEventListener('resize', setRealHeight);
</script>
