@page
@model RubberJointsAI.Pages.AIModel
@{
    Layout = "_Layout";
}

<div class="ai-container">
    <!-- Side Panel (conversation history) -->
    <div class="ai-sidebar" id="aiSidebar">
        <div class="ai-sidebar-header">
            <span class="ai-sidebar-title">Chats</span>
            <button class="ai-sidebar-close" id="closeSidebar">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <line x1="18" y1="6" x2="6" y2="18"></line>
                    <line x1="6" y1="6" x2="18" y2="18"></line>
                </svg>
            </button>
        </div>
        <button class="ai-new-chat" id="newChatBtn">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <line x1="12" y1="5" x2="12" y2="19"></line>
                <line x1="5" y1="12" x2="19" y2="12"></line>
            </svg>
            New Chat
        </button>
        <div class="ai-chat-list" id="chatList">
            <!-- Conversations will be added here -->
        </div>
    </div>

    <!-- Overlay for mobile sidebar -->
    <div class="ai-overlay" id="aiOverlay"></div>

    <!-- Main Chat Area -->
    <div class="ai-main">
        <!-- Top bar with menu toggle -->
        <div class="ai-topbar">
            <button class="ai-menu-btn" id="openSidebar">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <line x1="3" y1="6" x2="21" y2="6"></line>
                    <line x1="3" y1="12" x2="21" y2="12"></line>
                    <line x1="3" y1="18" x2="21" y2="18"></line>
                </svg>
            </button>
            <span class="ai-topbar-title">AI Coach</span>
            <div style="width:36px;"></div>
        </div>

        <!-- Messages area -->
        <div class="ai-messages" id="aiMessages">
            <!-- Welcome / status message from AI -->
            <div class="ai-message ai-message-assistant">
                <div class="ai-avatar">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M12 2L9 7l-5 1 3.5 3.5L7 17l5-2.5L17 17l-.5-5.5L20 8l-5-1z"></path>
                    </svg>
                </div>
                <div class="ai-bubble ai-bubble-assistant">
                    <div class="ai-typing" id="aiTyping">
                        <span></span><span></span><span></span>
                    </div>
                    <div class="ai-welcome-text" id="aiWelcome" style="display:none;">
                        <p><strong>Welcome back, @User.Identity?.Name!</strong></p>
                        <p>I'm your AI mobility coach. I can see your progress and help guide your training.</p>
                        <p class="ai-status-card">
                            <span class="ai-status-label">Program Status</span>
                            <span class="ai-status-value">Week 1 of 4</span>
                            <span class="ai-status-detail">Today is a <strong>Gym Session</strong> day</span>
                        </p>
                        <p>What would you like to know? You can ask me about your exercises, progress, or adjustments to your plan.</p>
                    </div>
                </div>
            </div>

            <!-- Quick suggestion chips -->
            <div class="ai-suggestions" id="aiSuggestions" style="display:none;">
                <button class="ai-chip" data-prompt="How am I progressing this week?">How am I progressing?</button>
                <button class="ai-chip" data-prompt="What should I focus on today?">Focus for today</button>
                <button class="ai-chip" data-prompt="Can you adjust my plan? I'm feeling sore.">I'm feeling sore</button>
                <button class="ai-chip" data-prompt="Tell me about my milestones">My milestones</button>
            </div>
        </div>

        <!-- Input area -->
        <div class="ai-input-area">
            <div class="ai-input-wrapper">
                <textarea class="ai-input" id="aiInput" placeholder="Ask your AI coach..." rows="1"></textarea>
                <button class="ai-send-btn" id="aiSendBtn" disabled>
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <line x1="22" y1="2" x2="11" y2="13"></line>
                        <polygon points="22 2 15 22 11 13 2 9 22 2"></polygon>
                    </svg>
                </button>
            </div>
            <div class="ai-disclaimer">AI responses are for guidance only. Consult a professional for medical advice.</div>
        </div>
    </div>
</div>

<script>
    // === Sidebar Toggle ===
    const sidebar = document.getElementById('aiSidebar');
    const overlay = document.getElementById('aiOverlay');
    const openBtn = document.getElementById('openSidebar');
    const closeBtn = document.getElementById('closeSidebar');

    function openSidebar() {
        sidebar.classList.add('open');
        overlay.classList.add('visible');
    }
    function closeSidebar() {
        sidebar.classList.remove('open');
        overlay.classList.remove('visible');
    }

    openBtn.addEventListener('click', openSidebar);
    closeBtn.addEventListener('click', closeSidebar);
    overlay.addEventListener('click', closeSidebar);

    // === Typing animation then reveal welcome ===
    setTimeout(() => {
        document.getElementById('aiTyping').style.display = 'none';
        document.getElementById('aiWelcome').style.display = 'block';
        document.getElementById('aiSuggestions').style.display = 'flex';
    }, 1500);

    // === Auto-resize textarea ===
    const input = document.getElementById('aiInput');
    const sendBtn = document.getElementById('aiSendBtn');

    input.addEventListener('input', function() {
        this.style.height = 'auto';
        this.style.height = Math.min(this.scrollHeight, 120) + 'px';
        sendBtn.disabled = this.value.trim().length === 0;
    });

    // === Send message (UI only, no AI backend yet) ===
    function sendMessage() {
        const text = input.value.trim();
        if (!text) return;

        // Add user message
        const messagesDiv = document.getElementById('aiMessages');
        const suggestionsDiv = document.getElementById('aiSuggestions');
        suggestionsDiv.style.display = 'none';

        const userMsg = document.createElement('div');
        userMsg.className = 'ai-message ai-message-user';
        userMsg.innerHTML = `<div class="ai-bubble ai-bubble-user">${escapeHtml(text)}</div>`;
        messagesDiv.appendChild(userMsg);

        // Clear input
        input.value = '';
        input.style.height = 'auto';
        sendBtn.disabled = true;

        // Add AI "thinking" response
        const aiMsg = document.createElement('div');
        aiMsg.className = 'ai-message ai-message-assistant';
        aiMsg.innerHTML = `
            <div class="ai-avatar">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M12 2L9 7l-5 1 3.5 3.5L7 17l5-2.5L17 17l-.5-5.5L20 8l-5-1z"></path>
                </svg>
            </div>
            <div class="ai-bubble ai-bubble-assistant">
                <div class="ai-typing"><span></span><span></span><span></span></div>
            </div>`;
        messagesDiv.appendChild(aiMsg);

        // Scroll to bottom
        messagesDiv.scrollTop = messagesDiv.scrollHeight;

        // Simulate AI response placeholder (will be replaced with real AI later)
        setTimeout(() => {
            const typingDot = aiMsg.querySelector('.ai-typing');
            if (typingDot) {
                typingDot.outerHTML = '<p style="color:var(--tx3);font-style:italic;">AI integration coming soon. This is where the response will appear.</p>';
            }
            messagesDiv.scrollTop = messagesDiv.scrollHeight;
        }, 2000);
    }

    sendBtn.addEventListener('click', sendMessage);
    input.addEventListener('keydown', function(e) {
        if (e.key === 'Enter' && !e.shiftKey) {
            e.preventDefault();
            sendMessage();
        }
    });

    // === Quick suggestion chips ===
    document.querySelectorAll('.ai-chip').forEach(chip => {
        chip.addEventListener('click', function() {
            input.value = this.dataset.prompt;
            input.dispatchEvent(new Event('input'));
            sendMessage();
        });
    });

    // === New Chat button ===
    document.getElementById('newChatBtn').addEventListener('click', function() {
        const messagesDiv = document.getElementById('aiMessages');
        // Keep only the welcome message
        while (messagesDiv.children.length > 2) {
            messagesDiv.removeChild(messagesDiv.lastChild);
        }
        document.getElementById('aiSuggestions').style.display = 'flex';
        closeSidebar();

        // Add to chat list
        addChatToList('New conversation');
    });

    // === Chat list management ===
    let chatCount = 0;
    function addChatToList(title) {
        chatCount++;
        const chatList = document.getElementById('chatList');
        const item = document.createElement('div');
        item.className = 'ai-chat-item active';

        // Deactivate other items
        chatList.querySelectorAll('.ai-chat-item').forEach(el => el.classList.remove('active'));

        const now = new Date();
        const time = now.toLocaleTimeString([], {hour: '2-digit', minute: '2-digit'});
        item.innerHTML = `
            <div class="ai-chat-item-title">${title}</div>
            <div class="ai-chat-item-time">${time}</div>`;
        chatList.prepend(item);
    }

    // Add initial chat entry
    addChatToList('Program check-in');

    function escapeHtml(text) {
        const div = document.createElement('div');
        div.textContent = text;
        return div.innerHTML;
    }
</script>
