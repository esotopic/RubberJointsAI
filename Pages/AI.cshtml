@page
@model RubberJointsAI.Pages.AIModel
@{
    Layout = "_Layout";
}

<div class="ai-container">
    <!-- Side Panel (conversation history) -->
    <div class="ai-sidebar" id="aiSidebar">
        <div class="ai-sidebar-header">
            <span class="ai-sidebar-title">Chats</span>
            <button class="ai-sidebar-close" id="closeSidebar">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <line x1="18" y1="6" x2="6" y2="18"></line>
                    <line x1="6" y1="6" x2="18" y2="18"></line>
                </svg>
            </button>
        </div>
        <button class="ai-new-chat" id="newChatBtn">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <line x1="12" y1="5" x2="12" y2="19"></line>
                <line x1="5" y1="12" x2="19" y2="12"></line>
            </svg>
            New Chat
        </button>
        <div class="ai-chat-list" id="chatList">
        </div>
    </div>

    <!-- Overlay for mobile sidebar -->
    <div class="ai-overlay" id="aiOverlay"></div>

    <!-- Main Chat Area -->
    <div class="ai-main">
        <!-- Top bar with menu toggle -->
        <div class="ai-topbar">
            <button class="ai-menu-btn" id="openSidebar">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <line x1="3" y1="6" x2="21" y2="6"></line>
                    <line x1="3" y1="12" x2="21" y2="12"></line>
                    <line x1="3" y1="18" x2="21" y2="18"></line>
                </svg>
            </button>
            <span class="ai-topbar-title">AI Coach</span>
            <div style="width:36px;"></div>
        </div>

        <!-- Program status banner (server-rendered, no AI call) -->
        @{
            string sessionLabel = Model.DayType switch {
                "gym" => "Gym Session",
                "home" => "Home Session",
                "recovery" => "Recovery",
                "rest" => "Rest Day",
                _ => "Today"
            };
            int progressPct = Model.TotalWeeks > 0 ? (int)((Model.Week - 1) * 100.0 / Model.TotalWeeks) : 0;
            if (progressPct > 100) progressPct = 100;
        }
        <div class="ai-status-banner">
            <div class="ai-status-banner-top">
                <div class="ai-status-banner-title">Week @Model.Week of @Model.TotalWeeks</div>
                <div class="ai-status-banner-phase">@Model.Phase Phase</div>
            </div>
            <div class="ai-status-banner-bar">
                <div class="ai-status-banner-fill" style="width:@(progressPct)%"></div>
            </div>
            <div class="ai-status-banner-grid">
                <div class="ai-status-banner-stat">
                    <span class="ai-stat-number">@Model.ExercisesDone/@Model.ExercisesTotal</span>
                    <span class="ai-stat-label">Exercises</span>
                </div>
                <div class="ai-status-banner-stat">
                    <span class="ai-stat-number">@Model.SupplementsDone/@Model.SupplementsTotal</span>
                    <span class="ai-stat-label">Supplements</span>
                </div>
                <div class="ai-status-banner-stat">
                    <span class="ai-stat-number">@Model.MilestonesDone/@Model.MilestonesTotal</span>
                    <span class="ai-stat-label">Milestones</span>
                </div>
                <div class="ai-status-banner-stat">
                    <span class="ai-stat-number">@sessionLabel</span>
                    <span class="ai-stat-label">Today</span>
                </div>
            </div>
        </div>

        <!-- Messages area -->
        <div class="ai-messages" id="aiMessages">

            <!-- Joke of the Day card -->
            <div class="ai-joke-card">
                <div class="ai-joke-icon">😂</div>
                <div class="ai-joke-text">"@Model.JokeOfTheDay"</div>
                <div class="ai-joke-tagline">— Your joints, probably</div>
            </div>

            <!-- Today's Quick Glance (server-rendered info) -->
            <div class="ai-info-card">
                <div class="ai-info-header">
                    <span class="ai-info-title">👋 Hey @User.Identity?.Name! Here's your day at a glance</span>
                </div>

                @if (Model.TodaysExercises.Any())
                {
                    <div class="ai-info-section">
                        <div class="ai-info-section-title">Today's Exercises</div>
                        @foreach (var ex in Model.TodaysExercises.Take(6))
                        {
                            <div class="ai-exercise-row @(ex.Done ? "done" : "")">
                                <span class="ai-exercise-check">@(ex.Done ? "✅" : "⬜")</span>
                                <span class="ai-exercise-name">@ex.Name</span>
                                <span class="ai-exercise-rx">@ex.Rx</span>
                            </div>
                        }
                        @if (Model.TodaysExercises.Count > 6)
                        {
                            <div class="ai-exercise-more">+ @(Model.TodaysExercises.Count - 6) more — check your Today tab</div>
                        }
                    </div>
                }

                @if (Model.UpcomingSupplements.Any())
                {
                    <div class="ai-info-section">
                        <div class="ai-info-section-title">💊 Supplements Still Due</div>
                        @foreach (var sup in Model.UpcomingSupplements)
                        {
                            <div class="ai-supplement-row">@sup</div>
                        }
                    </div>
                }

                <div class="ai-info-footer">
                    @if (Model.NextMilestone != null)
                    {
                        <div class="ai-info-nugget">🎯 Next milestone: <strong>@Model.NextMilestone</strong></div>
                    }
                    @if (Model.DaysRemaining > 0)
                    {
                        <div class="ai-info-nugget">📅 @Model.DaysRemaining days remaining in your program</div>
                    }
                    @if (Model.CompletedSessions > 0)
                    {
                        <div class="ai-info-nugget">🔥 @Model.CompletedSessions sessions completed so far — keep it up!</div>
                    }
                </div>
            </div>

            <!-- BIG START TRAINING BUTTON -->
            <a href="/" class="ai-start-training-btn">
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                    <polygon points="5 3 19 12 5 21 5 3"></polygon>
                </svg>
                START TRAINING
            </a>

            <!-- AI intro -->
            <div class="ai-message ai-message-assistant">
                <div class="ai-avatar">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M12 2L9 7l-5 1 3.5 3.5L7 17l5-2.5L17 17l-.5-5.5L20 8l-5-1z"></path>
                    </svg>
                </div>
                <div class="ai-bubble ai-bubble-assistant">
                    <p>Got questions? Tap a quick option below or type anything about your program.</p>
                </div>
            </div>
        </div>

        <!-- Quick action chips — always visible, pinned above input -->
        <div class="ai-suggestions" id="aiSuggestions">
            <button class="ai-chip" data-prompt="Give me a status update on where I am in my program — what week, what I've completed today, and how my overall progress looks.">
                My status update
            </button>
            <button class="ai-chip" data-prompt="What should I focus on in today's session? Any tips for getting the most out of my exercises?">
                Focus for today
            </button>
            <button class="ai-chip" data-prompt="How is my progress this week compared to what's expected? Am I on track?">
                Weekly progress
            </button>
            <button class="ai-chip" data-prompt="I'm feeling sore today. Can you suggest any adjustments to my plan or recovery tips?">
                I'm feeling sore
            </button>
            <button class="ai-chip" data-prompt="Tell me about my milestones — which ones have I hit and what should I aim for next?">
                My milestones
            </button>
            <button class="ai-chip" data-prompt="What supplements am I taking and when should I take them? Any tips?">
                Supplement guide
            </button>
        </div>

        <!-- Input area -->
        <div class="ai-input-area">
            <div class="ai-input-wrapper">
                <textarea class="ai-input" id="aiInput" placeholder="Ask your AI coach..." rows="1"></textarea>
                <button class="ai-send-btn" id="aiSendBtn" disabled>
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <line x1="22" y1="2" x2="11" y2="13"></line>
                        <polygon points="22 2 15 22 11 13 2 9 22 2"></polygon>
                    </svg>
                </button>
            </div>
            <!-- PROMINENT DISCLAIMER -->
            <div class="ai-disclaimer-prominent">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                    <path d="M10.29 3.86L1.82 18a2 2 0 001.71 3h16.94a2 2 0 001.71-3L13.71 3.86a2 2 0 00-3.42 0z"></path>
                    <line x1="12" y1="9" x2="12" y2="13"></line>
                    <line x1="12" y1="17" x2="12.01" y2="17"></line>
                </svg>
                <span><strong>Not medical advice.</strong> This is an AI assistant — not a doctor, trainer, or nutritionist. Always consult a professional before making health decisions.</span>
            </div>
        </div>
    </div>
</div>

<script>
    // === Sidebar Toggle ===
    const sidebar = document.getElementById('aiSidebar');
    const overlay = document.getElementById('aiOverlay');
    const openBtn = document.getElementById('openSidebar');
    const closeBtn = document.getElementById('closeSidebar');

    function openSidebar() {
        sidebar.classList.add('open');
        overlay.classList.add('visible');
    }
    function closeSidebar() {
        sidebar.classList.remove('open');
        overlay.classList.remove('visible');
    }

    openBtn.addEventListener('click', openSidebar);
    closeBtn.addEventListener('click', closeSidebar);
    overlay.addEventListener('click', closeSidebar);

    // === Auto-resize textarea ===
    const input = document.getElementById('aiInput');
    const sendBtn = document.getElementById('aiSendBtn');

    input.addEventListener('input', function() {
        this.style.height = 'auto';
        this.style.height = Math.min(this.scrollHeight, 120) + 'px';
        sendBtn.disabled = this.value.trim().length === 0;
    });

    // === Send message — calls real AI backend ===
    let isSending = false;

    async function sendMessage() {
        const text = input.value.trim();
        if (!text || isSending) return;
        isSending = true;

        const messagesDiv = document.getElementById('aiMessages');

        // Add user bubble
        const userMsg = document.createElement('div');
        userMsg.className = 'ai-message ai-message-user';
        userMsg.innerHTML = `<div class="ai-bubble ai-bubble-user">${escapeHtml(text)}</div>`;
        messagesDiv.appendChild(userMsg);

        // Clear input
        input.value = '';
        input.style.height = 'auto';
        sendBtn.disabled = true;

        // Add AI thinking bubble
        const aiMsg = document.createElement('div');
        aiMsg.className = 'ai-message ai-message-assistant';
        aiMsg.innerHTML = `
            <div class="ai-avatar">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M12 2L9 7l-5 1 3.5 3.5L7 17l5-2.5L17 17l-.5-5.5L20 8l-5-1z"></path>
                </svg>
            </div>
            <div class="ai-bubble ai-bubble-assistant">
                <div class="ai-typing"><span></span><span></span><span></span></div>
            </div>`;
        messagesDiv.appendChild(aiMsg);
        messagesDiv.scrollTop = messagesDiv.scrollHeight;

        try {
            const resp = await fetch('/api/ai/chat', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ message: text })
            });

            const data = await resp.json();
            const bubble = aiMsg.querySelector('.ai-bubble-assistant');

            if (data.success && data.response) {
                bubble.innerHTML = formatResponse(data.response);
            } else {
                bubble.innerHTML = `<p style="color:var(--red);">Sorry, I couldn't process that. ${data.error || 'Please try again.'}</p>`;
            }
        } catch (err) {
            const bubble = aiMsg.querySelector('.ai-bubble-assistant');
            bubble.innerHTML = `<p style="color:var(--red);">Connection error. Please check your internet and try again.</p>`;
        }

        messagesDiv.scrollTop = messagesDiv.scrollHeight;
        isSending = false;
    }

    // Format AI response text into HTML
    function formatResponse(text) {
        text = text.replace(/\*\*(.*?)\*\*/g, '<strong>$1</strong>');
        const paragraphs = text.split('\n\n').filter(p => p.trim());
        if (paragraphs.length > 1) {
            return paragraphs.map(p => `<p>${p.replace(/\n/g, '<br>')}</p>`).join('');
        }
        return `<p>${text.replace(/\n/g, '<br>')}</p>`;
    }

    sendBtn.addEventListener('click', sendMessage);
    input.addEventListener('keydown', function(e) {
        if (e.key === 'Enter' && !e.shiftKey) {
            e.preventDefault();
            sendMessage();
        }
    });

    // === Quick suggestion chips — trigger real AI call ===
    document.querySelectorAll('.ai-chip').forEach(chip => {
        chip.addEventListener('click', function() {
            input.value = this.dataset.prompt;
            input.dispatchEvent(new Event('input'));
            sendMessage();
        });
    });

    // === New Chat ===
    document.getElementById('newChatBtn').addEventListener('click', function() {
        const messagesDiv = document.getElementById('aiMessages');
        // Keep the joke card, info card, and AI intro (first 3 children)
        while (messagesDiv.children.length > 3) {
            messagesDiv.removeChild(messagesDiv.lastChild);
        }
        closeSidebar();
        addChatToList('New conversation');
    });

    // === Chat list ===
    let chatCount = 0;
    function addChatToList(title) {
        chatCount++;
        const chatList = document.getElementById('chatList');
        const item = document.createElement('div');
        item.className = 'ai-chat-item active';
        chatList.querySelectorAll('.ai-chat-item').forEach(el => el.classList.remove('active'));
        const now = new Date();
        const time = now.toLocaleTimeString([], {hour: '2-digit', minute: '2-digit'});
        item.innerHTML = `
            <div class="ai-chat-item-title">${title}</div>
            <div class="ai-chat-item-time">${time}</div>`;
        chatList.prepend(item);
    }
    addChatToList('New session');

    function escapeHtml(text) {
        const div = document.createElement('div');
        div.textContent = text;
        return div.innerHTML;
    }
</script>
