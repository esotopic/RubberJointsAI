@page
@model RubberJointsAI.Pages.AIModel
@{
    Layout = "_Layout";
    ViewData["HideUserBar"] = true;
}

<div class="ai-container">
    <!-- Side Panel (conversation history) -->
    <div class="ai-sidebar" id="aiSidebar">
        <div class="ai-sidebar-header">
            <span class="ai-sidebar-title">Chats</span>
            <button class="ai-sidebar-close" id="closeSidebar">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <line x1="18" y1="6" x2="6" y2="18"></line>
                    <line x1="6" y1="6" x2="18" y2="18"></line>
                </svg>
            </button>
        </div>
        <button class="ai-new-chat" id="newChatBtn">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <line x1="12" y1="5" x2="12" y2="19"></line>
                <line x1="5" y1="12" x2="19" y2="12"></line>
            </svg>
            New Chat
        </button>
        <div class="ai-chat-list" id="chatList">
        </div>
    </div>

    <!-- Overlay for mobile sidebar -->
    <div class="ai-overlay" id="aiOverlay"></div>

    <!-- Main Chat Area -->
    <div class="ai-main">
        <!-- Combined topbar + status in one row -->
        @{
            int progressPct = Model.TotalWeeks > 0 ? (int)((Model.Week - 1) * 100.0 / Model.TotalWeeks) : 0;
            if (progressPct > 100) progressPct = 100;
        }
        <div class="ai-topbar-combined">
            <button class="ai-menu-btn" id="openSidebar">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <line x1="3" y1="6" x2="21" y2="6"></line>
                    <line x1="3" y1="12" x2="21" y2="12"></line>
                    <line x1="3" y1="18" x2="21" y2="18"></line>
                </svg>
            </button>
            <div class="ai-topbar-center">
                <span class="ai-topbar-week">Week @Model.Week of @Model.TotalWeeks</span>
                <div class="ai-topbar-bar"><div class="ai-topbar-fill" style="width:@(progressPct)%"></div></div>
            </div>
            <div class="ai-status-banner-phase">@Model.Phase</div>
        </div>

        <!-- START TRAINING — fixed right below the status bar -->
        <a href="/Index" class="ai-start-training-btn">
            🔥 START TRAINING 💪
        </a>

        <!-- Messages area (scrollable) — joke, info, messages, and chips all scroll -->
        <div class="ai-messages" id="aiMessages">

            <!-- Joke card — scrolls with messages -->
            <div class="ai-joke-card ai-joke-in-scroll" id="jokeCard">
                <div class="ai-joke-icon">😂</div>
                <div class="ai-joke-text" id="jokeText"></div>
                <div class="ai-joke-tagline">— Your joints, probably</div>
            </div>

            <!-- Today's Quick Glance — compact 2-line summary -->
            <div class="ai-info-card ai-info-compact">
                <div class="ai-info-nugget" id="aiStatsLine">💪 Loading today's stats...</div>
                <div class="ai-info-nugget">📊 Check <strong>Progress</strong> tab to track your journey</div>
            </div>

            <!-- AI intro -->
            <div class="ai-message ai-message-assistant">
                <div class="ai-avatar">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M12 2L9 7l-5 1 3.5 3.5L7 17l5-2.5L17 17l-.5-5.5L20 8l-5-1z"></path>
                    </svg>
                </div>
                <div class="ai-bubble ai-bubble-assistant">
                    <p>Ask me anything about your program, exercises, or supplements!</p>
                </div>
            </div>

        </div>

        <!-- FIXED BOTTOM: chips + input + disclaimer — never scrolls -->
        <div class="ai-bottom-fixed">
            <div class="ai-suggestions-fixed" id="aiSuggestions">
                <button class="ai-chip" data-prompt="Give me a status update on where I am in my program — what week, what I've completed today, and how my overall progress looks.">
                    My status
                </button>
                <button class="ai-chip" data-prompt="What should I focus on in today's session? Any tips for getting the most out of my exercises?">
                    Today's focus
                </button>
                <button class="ai-chip" data-prompt="How is my progress this week compared to what's expected? Am I on track?">
                    Weekly progress
                </button>
            </div>
            <div class="ai-input-wrapper">
                <textarea class="ai-input" id="aiInput" placeholder="Ask your AI coach..." rows="1"></textarea>
                <button class="ai-send-btn" id="aiSendBtn" disabled>
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <line x1="22" y1="2" x2="11" y2="13"></line>
                        <polygon points="22 2 15 22 11 13 2 9 22 2"></polygon>
                    </svg>
                </button>
            </div>
            <div class="ai-disclaimer-slim">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                    <path d="M10.29 3.86L1.82 18a2 2 0 001.71 3h16.94a2 2 0 001.71-3L13.71 3.86a2 2 0 00-3.42 0z"></path>
                    <line x1="12" y1="9" x2="12" y2="13"></line>
                    <line x1="12" y1="17" x2="12.01" y2="17"></line>
                </svg>
                <span><strong>Not medical advice.</strong> Always consult a professional.</span>
            </div>
        </div>
    </div>
</div>

<script>
    // === JOKE ROTATION — changes on every page load AND every message ===
    const jokes = [
        "My knees sound like a haunted house every time I use the stairs.",
        "I don't need an alarm clock. My joints crack so loud they wake up the whole house.",
        "At 20, I could touch my toes. At 40, I'm happy if I can see them.",
        "My doctor said I should do lunges to stay in shape. That would be a big step forward.",
        "I told my knee to stop making noise. It said it was just trying to get a-joint-ment.",
        "The only snaps, crackles, and pops I get now are from my body, not my cereal.",
        "I stretched this morning and my back made a sound like bubble wrap at a birthday party.",
        "My hip flexors are so tight, they have their own zip code.",
        "My body doesn't wake up anymore — it negotiates with gravity first.",
        "I used to be flexible. Now I pull a muscle reaching for the TV remote.",
        "My joints predict the weather better than any app on my phone.",
        "Getting out of bed used to take 2 seconds. Now it's a 5-stage process with sound effects.",
        "My physical therapist laughed when I said I wanted to touch my toes. Then I laughed. Then we both cried.",
        "I tried yoga once. The instructor said 'listen to your body.' My body said 'absolutely not.'",
        "Age is just a number. But so is your creak-per-squat ratio, and mine is off the charts.",
        "My knees are like popcorn — they pop at random and everyone around me can hear it.",
        "I used to party until 2 AM. Now my joints party every time I stand up.",
        "I don't stretch before exercise. I stretch before bending down to tie my shoes.",
        "My ankles crack so loud, my neighbors asked if I was making popcorn.",
        "Whoever said 'no pain, no gain' clearly never tried standing up after sitting on the floor.",
        "I'm not old, I'm just... pre-owned with some joint noise.",
        "My morning stretch routine sounds like someone stepping on Legos in a hallway.",
        "I went to the gym and the trainer asked my fitness level. I said 'I can open a jar without crying.'",
        "My joints have more complaints than a Yelp review section.",
        "I thought my knee cracked because of arthritis. Turns out it's just applauding me for trying.",
        "My skeleton sounds like a percussion section warming up.",
        "I sneezed and threw out my back. That's my villain origin story.",
        "My chiropractor has a frequent visitor card. I'm on my third one.",
        "I don't crack my knuckles for fun. My knuckles crack themselves to assert dominance.",
        "My joints pop so much, I'm basically a one-person band.",
        "I dropped something on the floor. It lives there now.",
        "My elbows sound like someone crumpling a paper bag every time I do a push-up.",
        "My hips don't lie. And right now they're saying 'not today, buddy.'",
        "I told my trainer I wanted a body like a Greek god. He said 'you already creak like an ancient relic.'",
        "Stairs used to be transportation. Now they're a cardio workout with a soundtrack.",
        "My shoulder cracks louder than my phone notification. People think I'm getting texts.",
        "I used to run marathons. Now I run out of breath walking to the fridge.",
        "I sat on the floor to play with my kids. I'm still trying to get back up. Send help.",
        "My joints are so noisy, even my dog looks at me funny when I stand up.",
        "I foam-rolled once. It was like a horror movie but I was both the victim and the monster.",
        "If my joints had a Spotify playlist, it would be called 'Snap, Crackle & Suffering.'",
        "My wrists crack so much, people think I'm typing in Morse code.",
        "I call my morning stretch routine 'the symphony of regret.'",
        "My right knee and left knee are in a competition to see who can be louder. Nobody wins.",
        "I can't sneak up on anyone anymore. My ankles announce me three rooms away.",
        "I asked my joints to be quiet. They said they'd file a noise complaint about my snoring first.",
        "My spine sounds like a zipper every time I twist. A really old, rusty zipper.",
        "The last time I was limber, dial-up internet was still a thing.",
        "My joints pop so often I started counting. I lost count by breakfast.",
        "I bent over to pick up my keys and my body played the entire percussion section of Beethoven's Fifth.",
    ];

    let jokeIndex = Math.floor(Math.random() * jokes.length);

    function showNewJoke() {
        jokeIndex = (jokeIndex + 1) % jokes.length;
        const jokeText = document.getElementById('jokeText');
        if (jokeText) {
            jokeText.style.opacity = '0';
            setTimeout(() => {
                jokeText.textContent = '"' + jokes[jokeIndex] + '"';
                jokeText.style.opacity = '1';
            }, 200);
        }
    }

    // Show a random joke on page load
    document.getElementById('jokeText').textContent = '"' + jokes[jokeIndex] + '"';

    // === Sidebar Toggle ===
    const sidebar = document.getElementById('aiSidebar');
    const overlay = document.getElementById('aiOverlay');
    const openBtn = document.getElementById('openSidebar');
    const closeBtn = document.getElementById('closeSidebar');

    function openSidebar() {
        sidebar.classList.add('open');
        overlay.classList.add('visible');
    }
    function closeSidebar() {
        sidebar.classList.remove('open');
        overlay.classList.remove('visible');
    }

    openBtn.addEventListener('click', openSidebar);
    closeBtn.addEventListener('click', closeSidebar);
    overlay.addEventListener('click', closeSidebar);

    // === Auto-resize textarea ===
    const input = document.getElementById('aiInput');
    const sendBtn = document.getElementById('aiSendBtn');

    input.addEventListener('input', function() {
        this.style.height = 'auto';
        this.style.height = Math.min(this.scrollHeight, 120) + 'px';
        sendBtn.disabled = this.value.trim().length === 0;
    });

    // === Send message — calls real AI backend ===
    let isSending = false;

    async function sendMessage() {
        const text = input.value.trim();
        if (!text || isSending) return;
        isSending = true;

        // Rotate joke on every message
        showNewJoke();

        const messagesDiv = document.getElementById('aiMessages');

        // Add user bubble
        const userMsg = document.createElement('div');
        userMsg.className = 'ai-message ai-message-user';
        userMsg.innerHTML = `<div class="ai-bubble ai-bubble-user">${escapeHtml(text)}</div>`;
        messagesDiv.appendChild(userMsg);

        // Clear input
        input.value = '';
        input.style.height = 'auto';
        sendBtn.disabled = true;

        // Add AI thinking bubble
        const aiMsg = document.createElement('div');
        aiMsg.className = 'ai-message ai-message-assistant';
        aiMsg.innerHTML = `
            <div class="ai-avatar">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M12 2L9 7l-5 1 3.5 3.5L7 17l5-2.5L17 17l-.5-5.5L20 8l-5-1z"></path>
                </svg>
            </div>
            <div class="ai-bubble ai-bubble-assistant">
                <div class="ai-typing"><span></span><span></span><span></span></div>
            </div>`;
        messagesDiv.appendChild(aiMsg);
        messagesDiv.scrollTop = messagesDiv.scrollHeight;

        try {
            const resp = await fetch('/api/ai/chat', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ message: text })
            });

            const data = await resp.json();
            const bubble = aiMsg.querySelector('.ai-bubble-assistant');

            if (data.success && data.response) {
                bubble.innerHTML = formatResponse(data.response);
            } else {
                bubble.innerHTML = `<p style="color:var(--red);">Sorry, I couldn't process that. ${data.error || 'Please try again.'}</p>`;
            }
        } catch (err) {
            const bubble = aiMsg.querySelector('.ai-bubble-assistant');
            bubble.innerHTML = `<p style="color:var(--red);">Connection error. Please check your internet and try again.</p>`;
        }

        messagesDiv.scrollTop = messagesDiv.scrollHeight;
        isSending = false;
    }

    // Format AI response text into HTML
    function formatResponse(text) {
        text = text.replace(/\*\*(.*?)\*\*/g, '<strong>$1</strong>');
        const paragraphs = text.split('\n\n').filter(p => p.trim());
        if (paragraphs.length > 1) {
            return paragraphs.map(p => `<p>${p.replace(/\n/g, '<br>')}</p>`).join('');
        }
        return `<p>${text.replace(/\n/g, '<br>')}</p>`;
    }

    sendBtn.addEventListener('click', sendMessage);
    input.addEventListener('keydown', function(e) {
        if (e.key === 'Enter' && !e.shiftKey) {
            e.preventDefault();
            sendMessage();
        }
    });

    // === Quick suggestion chips — trigger real AI call ===
    document.querySelectorAll('.ai-chip').forEach(chip => {
        chip.addEventListener('click', function() {
            input.value = this.dataset.prompt;
            input.dispatchEvent(new Event('input'));
            sendMessage();
        });
    });

    // === New Chat ===
    document.getElementById('newChatBtn').addEventListener('click', function() {
        const messagesDiv = document.getElementById('aiMessages');
        // Keep the info card and AI intro (first 2 children)
        while (messagesDiv.children.length > 2) {
            messagesDiv.removeChild(messagesDiv.lastChild);
        }
        showNewJoke();
        closeSidebar();
        addChatToList('New conversation');
    });

    // === Chat list ===
    let chatCount = 0;
    function addChatToList(title) {
        chatCount++;
        const chatList = document.getElementById('chatList');
        const item = document.createElement('div');
        item.className = 'ai-chat-item active';
        chatList.querySelectorAll('.ai-chat-item').forEach(el => el.classList.remove('active'));
        const now = new Date();
        const time = now.toLocaleTimeString([], {hour: '2-digit', minute: '2-digit'});
        item.innerHTML = `
            <div class="ai-chat-item-title">${title}</div>
            <div class="ai-chat-item-time">${time}</div>`;
        chatList.prepend(item);
    }
    addChatToList('New session');

    function escapeHtml(text) {
        const div = document.createElement('div');
        div.textContent = text;
        return div.innerHTML;
    }

    // === Auto-send prompt from query parameter (e.g., from "Ask AI" buttons on Today page) ===
    (function() {
        const params = new URLSearchParams(window.location.search);
        const autoPrompt = params.get('prompt');
        if (autoPrompt && autoPrompt.trim()) {
            // Clean up the URL so refreshing doesn't re-send
            window.history.replaceState({}, '', '/AI');
            // Set the input and send after a short delay to let page initialize
            setTimeout(() => {
                input.value = autoPrompt.trim();
                input.dispatchEvent(new Event('input'));
                sendMessage();
            }, 300);
        }
    })();

    // === Load today's stats (exercise/supplement counts) in background ===
    fetch('/api/ai-stats', { credentials: 'same-origin' })
        .then(r => r.json())
        .then(d => {
            if (d.success) {
                const el = document.getElementById('aiStatsLine');
                if (el) el.textContent = '💪 ' + d.exercisesDone + '/' + d.exercisesTotal + ' exercises · ' + d.supplementsDone + '/' + d.supplementsTotal + ' supplements';
            }
        })
        .catch(() => {
            const el = document.getElementById('aiStatsLine');
            if (el) el.textContent = '💪 Check Today tab for your progress';
        });

    // === Prefetch Today page data in background to warm server cache ===
    fetch('/api/today-prefetch', { credentials: 'same-origin' }).catch(() => {});
</script>
