@page
@model ProgressModel

@{
    ViewData["Title"] = "Progress";
    var stepsPercent = Model.ViewModel.TodayStepsTotal > 0
        ? (int)((Model.ViewModel.TodayStepsDone * 100) / Model.ViewModel.TodayStepsTotal)
        : 0;
}

<div class="page-content">
    @if (!string.IsNullOrEmpty(Model.ViewModel.ErrorMessage))
    {
        <div class="error-banner">@Model.ViewModel.ErrorMessage</div>
    }

    <!-- Header -->
    <section class="activity-summary" style="text-align:center;">
        <h2 class="activity-title" style="letter-spacing:0.12em;">Progress</h2>
        @if (Model.ViewModel.Week > 0)
        {
            <span class="week-pill">Week @Model.ViewModel.Week of 4</span>
        }
    </section>

    <!-- Stats Grid -->
    <div class="stat-grid">
        <div class="stat-box">
            <div class="stat-value">@Model.ViewModel.SessionsThisWeek</div>
            <div class="stat-label">This Week</div>
        </div>
        <div class="stat-box">
            <div class="stat-value">@Model.ViewModel.SessionsTotal</div>
            <div class="stat-label">Total Sessions</div>
        </div>
        <div class="stat-box">
            <div class="stat-value">@stepsPercent%</div>
            <div class="stat-label">Today's Session</div>
        </div>
        <div class="stat-box">
            <div class="stat-value">@Model.ViewModel.TodaySuppsDone/@Model.ViewModel.TodaySuppsTotal</div>
            <div class="stat-label">Vitamins Today</div>
        </div>
    </div>

    @if (Model.ViewModel.Milestones.Any())
    {
        <!-- Milestones Card -->
        <div class="card" style="margin:0 16px 14px;">
            <div class="card-title" style="font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:0.07em;color:var(--tx3);margin-bottom:10px;">Milestones</div>
            @{
                var milestoneDescriptions = new Dictionary<string, string>
                {
                    ["kneel"] = "Kneel on a hard floor with no padding and hold comfortably for 30+ seconds. This tests knee and ankle mobility and shows your joints are adapting to load.",
                    ["squat60"] = "Hold a deep squat (full depth, heels down) for 60 seconds. A fundamental mobility benchmark that shows hip, knee, and ankle flexibility.",
                    ["squat120"] = "Hold a deep squat for 2 full minutes without support. This shows strong lower-body mobility and endurance in end-range positions.",
                    ["hang30"] = "Hang from a pull-up bar with straight arms for 30 seconds. Builds shoulder health, grip strength, and spinal decompression.",
                    ["hang60"] = "Dead hang for a full minute. Demonstrates excellent shoulder mobility and grip endurance — a key joint health marker.",
                    ["shinbox"] = "From a shinbox (90-90) position, stand up without using your hands. Tests hip mobility, glute strength, and balance.",
                    ["tgu-kb"] = "Complete a full Turkish get-up holding a kettlebell. This full-body movement tests shoulder stability, core strength, and coordinated mobility.",
                    ["cossack-floor"] = "Perform a Cossack squat deep enough to touch the floor with your hand. Demands exceptional hip and ankle mobility with lateral movement.",
                    ["floor-nohand"] = "Get up from the floor to standing without using your hands or knees. A classic functional mobility test used in longevity research."
                };
            }
            @foreach (var milestone in Model.ViewModel.Milestones)
            {
                var msDesc = milestoneDescriptions.ContainsKey(milestone.Id) ? milestoneDescriptions[milestone.Id] : "A mobility milestone in your program.";
                <div class="ms-item" data-milestone-id="@milestone.Id">
                    <div class="ms-dot @(milestone.Done ? "done" : "")" data-milestone-id="@milestone.Id">
                        @if (milestone.Done)
                        {
                            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg>
                        }
                    </div>
                    <div class="ms-content ms-content-tap">
                        <div class="ms-name">@milestone.Name</div>
                        <div class="ms-date">
                            @if (milestone.Done && !string.IsNullOrEmpty(milestone.AchievedDate))
                            {
                                <text>Achieved @FormatDate(milestone.AchievedDate)</text>
                            }
                            else
                            {
                                <text>Not yet</text>
                            }
                        </div>
                    </div>
                    @if (!milestone.Done)
                    {
                        <button class="ms-btn" data-milestone-id="@milestone.Id">Done</button>
                    }
                </div>
                <div class="ms-detail" data-ms-detail="@milestone.Id">
                    <p>@msDesc</p>
                    <a href="https://www.youtube.com/results?search_query=@(Uri.EscapeDataString(milestone.Name + " mobility exercise"))"
                       target="_blank" rel="noopener" class="yt-demo-link">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M23.5 6.2a3 3 0 00-2.1-2.1C19.5 3.5 12 3.5 12 3.5s-7.5 0-9.4.6A3 3 0 00.5 6.2 31.9 31.9 0 000 12a31.9 31.9 0 00.5 5.8 3 3 0 002.1 2.1c1.9.6 9.4.6 9.4.6s7.5 0 9.4-.6a3 3 0 002.1-2.1A31.9 31.9 0 0024 12a31.9 31.9 0 00-.5-5.8zM9.5 15.6V8.4l6.3 3.6-6.3 3.6z"/></svg>
                        Watch Demo
                    </a>
                </div>
            }
        </div>
    }

    <div style="text-align:center;padding:16px;color:var(--tx3);font-size:12px;">
        Sessions are saved automatically
    </div>

    <div style="height: 100px;"></div>
</div>

<script>
// Milestone "Done" button click
document.querySelectorAll('.ms-btn').forEach(btn => {
    btn.addEventListener('click', async () => {
        const milestoneId = btn.dataset.milestoneId;
        const item = btn.closest('.ms-item');
        const dot = item.querySelector('.ms-dot');

        try {
            const response = await fetch('/api/milestone', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ id: milestoneId })
            });

            if (response.ok) {
                // Update UI
                dot.classList.add('done');
                dot.innerHTML = '<svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg>';
                const dateEl = item.querySelector('.ms-date');
                if (dateEl) dateEl.textContent = 'Achieved today';
                btn.remove();
            }
        } catch (error) {
            console.error('Error:', error);
        }
    });
});

// Tap milestone name to expand/collapse detail
document.querySelectorAll('.ms-content-tap').forEach(content => {
    content.style.cursor = 'pointer';
    content.addEventListener('click', (e) => {
        e.stopPropagation();
        const item = content.closest('.ms-item');
        const msId = item.dataset.milestoneId;
        const detail = document.querySelector(`.ms-detail[data-ms-detail="${msId}"]`);
        if (detail) {
            detail.classList.toggle('open');
        }
    });
});

// Auto-log session on page load (fire and forget)
fetch('/api/logsession', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({})
}).catch(() => {});
</script>

@functions {
    private string FormatDate(string dateStr)
    {
        if (DateTime.TryParse(dateStr, out var date))
        {
            return date.ToString("MMM d, yyyy");
        }
        return dateStr;
    }
}
