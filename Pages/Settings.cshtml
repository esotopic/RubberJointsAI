@page
@model SettingsModel

@{
    ViewData["Title"] = "Settings";
}

<div class="page-content">
    @if (!string.IsNullOrEmpty(Model.ErrorMessage))
    {
        <div class="error-banner">@Model.ErrorMessage</div>
    }

    @if (!string.IsNullOrEmpty(Model.SuccessMessage))
    {
        <div class="success-banner" style="background:rgba(52,199,89,0.1);color:var(--grn);padding:12px 16px;margin:0 16px 12px;border-radius:10px;font-size:13px;font-weight:500;text-align:center;">@Model.SuccessMessage</div>
    }

    <section class="activity-summary" style="text-align:center;">
        <h2 class="activity-title" style="letter-spacing:0.12em;">Settings</h2>
    </section>

    <!-- Program Start Date -->
    <form method="post" id="settingsForm">
        <div class="settings-card">
            <div class="settings-card-title">Program Start Date</div>
            <div class="setting-row">
                <div>
                    <div class="setting-label">When did you start?</div>
                    <div class="setting-sub">
                        @if (!string.IsNullOrEmpty(Model.StartDate))
                        {
                            <text>Week @Model.CurrentWeek · Phase @Model.CurrentPhase: @GetPhaseLabel(Model.CurrentPhase)</text>
                        }
                        else
                        {
                            <text>Not set — defaults to Week 1</text>
                        }
                    </div>
                </div>
                <input type="date" id="StartDate" name="StartDate" value="@Model.StartDate">
            </div>
        </div>
        <button type="submit" class="btn-save">Save Start Date</button>
    </form>

    <!-- Warm-Up Exercises -->
    <div class="settings-card">
        <div class="cat-header">
            <span class="cat-icon">🔥</span>
            <span class="cat-title">Warm-Up</span>
            <span class="cat-count" id="warmup-count">@(Model.WarmupExercises.Count(e => Model.SelectedExerciseIds.Contains(e.Id))) / @Model.WarmupExercises.Count</span>
        </div>
        @foreach (var ex in Model.WarmupExercises)
        {
            var isOn = Model.SelectedExerciseIds.Contains(ex.Id);
            <div class="settings-toggle-row">
                <div class="toggle-info">
                    <div class="toggle-name">@ex.Name</div>
                    <div class="toggle-desc">@ex.Targets</div>
                    @if (!string.IsNullOrEmpty(ex.DefaultRx))
                    {
                        <div class="toggle-rx">@ex.DefaultRx</div>
                    }
                </div>
                <label class="settings-toggle" data-exercise-id="@ex.Id">
                    <input type="checkbox" @(isOn ? "checked" : "")>
                    <span class="slider"></span>
                </label>
            </div>
        }
    </div>

    <!-- Mobility Exercises -->
    <div class="settings-card">
        <div class="cat-header">
            <span class="cat-icon">🧘</span>
            <span class="cat-title">Mobility</span>
            <span class="cat-count" id="mobility-count">@(Model.MobilityExercises.Count(e => Model.SelectedExerciseIds.Contains(e.Id))) / @Model.MobilityExercises.Count</span>
        </div>
        @foreach (var ex in Model.MobilityExercises)
        {
            var isOn = Model.SelectedExerciseIds.Contains(ex.Id);
            <div class="settings-toggle-row">
                <div class="toggle-info">
                    <div class="toggle-name">@ex.Name</div>
                    <div class="toggle-desc">@ex.Targets</div>
                    @if (!string.IsNullOrEmpty(ex.DefaultRx))
                    {
                        <div class="toggle-rx">@ex.DefaultRx</div>
                    }
                </div>
                <label class="settings-toggle" data-exercise-id="@ex.Id">
                    <input type="checkbox" @(isOn ? "checked" : "")>
                    <span class="slider"></span>
                </label>
            </div>
        }
    </div>

    <!-- Recovery Tools -->
    <div class="settings-card">
        <div class="cat-header">
            <span class="cat-icon">🧊</span>
            <span class="cat-title">Recovery</span>
            <span class="cat-count" id="recovery-count">@(Model.RecoveryExercises.Count(e => Model.SelectedExerciseIds.Contains(e.Id))) / @Model.RecoveryExercises.Count</span>
        </div>
        @foreach (var ex in Model.RecoveryExercises)
        {
            var isOn = Model.SelectedExerciseIds.Contains(ex.Id);
            <div class="settings-toggle-row">
                <div class="toggle-info">
                    <div class="toggle-name">@ex.Name</div>
                    <div class="toggle-desc">@ex.Targets</div>
                    @if (!string.IsNullOrEmpty(ex.DefaultRx))
                    {
                        <div class="toggle-rx">@ex.DefaultRx</div>
                    }
                </div>
                <label class="settings-toggle" data-exercise-id="@ex.Id">
                    <input type="checkbox" @(isOn ? "checked" : "")>
                    <span class="slider"></span>
                </label>
            </div>
        }
    </div>

    <!-- Supplements -->
    <div class="settings-card">
        <div class="cat-header">
            <span class="cat-icon">💊</span>
            <span class="cat-title">Supplements</span>
            <span class="cat-count" id="supp-count">@(Model.AllSupplements.Count(s => Model.SelectedSupplementIds.Contains(s.Id))) / @Model.AllSupplements.Count</span>
        </div>
        @foreach (var s in Model.AllSupplements)
        {
            var isOn = Model.SelectedSupplementIds.Contains(s.Id);
            <div class="settings-toggle-row">
                <div class="toggle-info">
                    <div class="toggle-name">@s.Name</div>
                    <div class="toggle-desc">@(s.Dose ?? "")</div>
                    @if (!string.IsNullOrEmpty(s.Time))
                    {
                        <div class="toggle-rx">@s.Time</div>
                    }
                </div>
                <label class="settings-toggle" data-supplement-id="@s.Id">
                    <input type="checkbox" @(isOn ? "checked" : "")>
                    <span class="slider"></span>
                </label>
            </div>
        }
    </div>

    <!-- Data / Reset Section -->
    <div class="settings-card">
        <div class="settings-card-title">Data</div>
        <div class="setting-row">
            <div>
                <div class="setting-label">Reset all progress</div>
                <div class="setting-sub">This cannot be undone</div>
            </div>
            <form method="post" asp-page-handler="reset" id="resetForm" style="margin:0;" onsubmit="return confirm('Are you sure you want to reset all progress? This cannot be undone.');">
                <button type="submit" id="resetBtn" class="btn-reset">Reset</button>
            </form>
        </div>
    </div>

    <div style="height: 100px;"></div>
</div>

<script>
// Instant toggle via API — exercises
document.querySelectorAll('.settings-toggle[data-exercise-id]').forEach(label => {
    const checkbox = label.querySelector('input');
    checkbox.addEventListener('change', async () => {
        label.classList.add('saving');
        try {
            const res = await fetch('/api/preferences/toggle', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ exerciseId: label.dataset.exerciseId, enabled: checkbox.checked })
            });
            const data = await res.json();
            if (!data.success) {
                checkbox.checked = !checkbox.checked; // revert
            }
        } catch {
            checkbox.checked = !checkbox.checked; // revert on error
        }
        label.classList.remove('saving');
        updateCounts();
    });
});

// Instant toggle via API — supplements
document.querySelectorAll('.settings-toggle[data-supplement-id]').forEach(label => {
    const checkbox = label.querySelector('input');
    checkbox.addEventListener('change', async () => {
        label.classList.add('saving');
        try {
            const res = await fetch('/api/preferences/toggle', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ supplementId: label.dataset.supplementId, enabled: checkbox.checked })
            });
            const data = await res.json();
            if (!data.success) {
                checkbox.checked = !checkbox.checked;
            }
        } catch {
            checkbox.checked = !checkbox.checked;
        }
        label.classList.remove('saving');
        updateCounts();
    });
});

function updateCounts() {
    const count = (selector) => {
        const toggles = document.querySelectorAll(selector);
        const on = Array.from(toggles).filter(t => t.querySelector('input').checked).length;
        return `${on} / ${toggles.length}`;
    };
    const wc = document.getElementById('warmup-count');
    const mc = document.getElementById('mobility-count');
    const rc = document.getElementById('recovery-count');
    const sc = document.getElementById('supp-count');

    // Group by category cards
    const cards = document.querySelectorAll('.settings-card');
    cards.forEach(card => {
        const header = card.querySelector('.cat-count');
        if (!header) return;
        const toggles = card.querySelectorAll('.settings-toggle');
        const on = Array.from(toggles).filter(t => t.querySelector('input').checked).length;
        header.textContent = `${on} / ${toggles.length}`;
    });
}
</script>

@functions {
    private string GetPhaseLabel(int phase)
    {
        return phase switch
        {
            1 => "Foundation",
            2 => "Strength",
            _ => "Unknown"
        };
    }
}
