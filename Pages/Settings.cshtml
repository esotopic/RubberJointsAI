@page
@model SettingsModel

@{
    ViewData["Title"] = "Settings";
}

<div class="page-content">
    @if (!string.IsNullOrEmpty(Model.ErrorMessage))
    {
        <div class="error-banner">@Model.ErrorMessage</div>
    }

    @if (!string.IsNullOrEmpty(Model.SuccessMessage))
    {
        <div class="success-banner" style="background:rgba(52,199,89,0.1);color:var(--grn);padding:12px 16px;margin:0 16px 12px;border-radius:10px;font-size:13px;font-weight:500;text-align:center;">@Model.SuccessMessage</div>
    }

    <!-- Header -->
    <section class="activity-summary" style="text-align:center;">
        <h2 class="activity-title" style="letter-spacing:0.12em;">Settings</h2>
    </section>

    <form method="post" id="settingsForm">
        <!-- Program Start Date -->
        <div class="settings-card">
            <div class="settings-card-title">Program Start Date</div>
            <div class="setting-row">
                <div>
                    <div class="setting-label">When did you start?</div>
                    <div class="setting-sub">
                        @if (!string.IsNullOrEmpty(Model.StartDate))
                        {
                            <text>Week @Model.CurrentWeek · Phase @Model.CurrentPhase: @GetPhaseLabel(Model.CurrentPhase)</text>
                        }
                        else
                        {
                            <text>Not set — defaults to Week 1</text>
                        }
                    </div>
                </div>
                <input type="date" id="StartDate" name="StartDate" value="@Model.StartDate">
            </div>
        </div>

        <!-- Recovery Tools -->
        <div class="settings-card">
            <div class="settings-card-title">Recovery Tools Available</div>
            <div class="settings-card-desc">Disabled tools are removed from sessions</div>

            @{
                var tools = new[] {
                    ("hot-tub", "Hot Tub"),
                    ("vibration-plate", "Vibration Plate"),
                    ("hydro-massager", "Hydro Massager"),
                    ("steam-sauna", "Steam Sauna"),
                    ("dry-sauna", "Dry Sauna"),
                    ("compex-warmup", "Compex Warm-Up"),
                    ("compex-recovery", "Compex Recovery"),
                    ("compression-boots", "Compression Boots")
                };
            }

            @foreach (var (id, label) in tools)
            {
                var isEnabled = Model.RecoveryTools.ContainsKey(id) && Model.RecoveryTools[id];
                <div class="setting-row">
                    <div class="setting-label">@label</div>
                    <input type="hidden" name="RecoveryTools[@id]" value="false" class="tool-hidden" data-tool="@id">
                    <div class="toggle @(isEnabled ? "on" : "")" data-tool="@id">
                        <i></i>
                    </div>
                </div>
            }
        </div>

        <button type="submit" class="btn-save">Save Settings</button>
    </form>

    <!-- Data / Reset Section -->
    <div class="settings-card">
        <div class="settings-card-title">Data</div>
        <div class="setting-row">
            <div>
                <div class="setting-label">Reset all progress</div>
                <div class="setting-sub">This cannot be undone</div>
            </div>
            <form method="post" asp-page-handler="reset" style="margin:0;">
                <button type="button" id="resetBtn" class="btn-reset">Reset</button>
            </form>
        </div>
    </div>

    <div style="height: 100px;"></div>
</div>

<script>
// Toggle switches
document.querySelectorAll('.toggle[data-tool]').forEach(tog => {
    tog.addEventListener('click', () => {
        tog.classList.toggle('on');
        const toolId = tog.dataset.tool;
        const hidden = document.querySelector(`.tool-hidden[data-tool="${toolId}"]`);
        if (hidden) {
            hidden.value = tog.classList.contains('on') ? 'true' : 'false';
        }
    });
});

// Set initial hidden values for enabled tools
document.querySelectorAll('.toggle.on[data-tool]').forEach(tog => {
    const toolId = tog.dataset.tool;
    const hidden = document.querySelector(`.tool-hidden[data-tool="${toolId}"]`);
    if (hidden) hidden.value = 'true';
});

// Reset confirmation
const resetBtn = document.getElementById('resetBtn');
if (resetBtn) {
    resetBtn.addEventListener('click', () => {
        if (confirm('Are you sure you want to reset all progress? This cannot be undone.')) {
            resetBtn.closest('form').submit();
        }
    });
}
</script>

@functions {
    private string GetPhaseLabel(int phase)
    {
        return phase switch
        {
            1 => "Foundation",
            2 => "Strength",
            _ => "Unknown"
        };
    }
}
