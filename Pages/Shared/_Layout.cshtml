@inject RubberJointsAI.Data.RubberJointsAIRepository LayoutRepo

@{
    bool isOnboarding = false;
    if (User.Identity?.IsAuthenticated == true)
    {
        try
        {
            var uid = User.Identity.Name ?? "default";
            var prefs = await LayoutRepo.GetUserPreferencesAsync(uid);
            isOnboarding = prefs == null || prefs.OnboardingStep < 7;
        }
        catch { }
    }
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
    <meta name="theme-color" content="#f5f5f7">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
    <meta name="apple-mobile-web-app-title" content="RubberJoints">
    <title>RubberJoints</title>
    <link rel="stylesheet" href="~/css/site.css">
</head>
<body>
    <main class="page-container">
        @if (User.Identity?.IsAuthenticated == true && ViewData["HideUserBar"] == null)
        {
            <div style="display:flex;justify-content:space-between;align-items:center;padding:8px 16px 0;">
                <span style="color:var(--t2);font-size:0.8rem;">@User.Identity.Name</span>
                <a href="/Logout" style="color:var(--t2);font-size:0.8rem;text-decoration:none;">Sign out</a>
            </div>
        }
        @RenderBody()
    </main>

    <nav class="bottom-nav" data-nav="@ViewContext.HttpContext.Request.Path">
        <a href="/AI" class="nav-item @(ViewContext.HttpContext.Request.Path == "/AI" ? "active" : "")" data-path="/AI">
            <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M12 2L9 7l-5 1 3.5 3.5L7 17l5-2.5L17 17l-.5-5.5L20 8l-5-1z"></path>
                <circle cx="12" cy="9" r="1" fill="currentColor" stroke="none"></circle>
            </svg>
            <span class="nav-label">AI</span>
        </a>
        <a href="@(isOnboarding ? "/AI" : "/Index")" class="nav-item @(isOnboarding ? "locked" : "") @(ViewContext.HttpContext.Request.Path == "/Index" || ViewContext.HttpContext.Request.Path == "/" ? "active" : "")" data-path="/Index">
            <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <circle cx="12" cy="12" r="1"></circle>
                <path d="M12 1v6m0 6v6"></path>
                <path d="M4.22 4.22l4.24 4.24m5.08 5.08l4.24 4.24"></path>
                <path d="M1 12h6m6 0h6"></path>
                <path d="M4.22 19.78l4.24-4.24m5.08-5.08l4.24-4.24"></path>
            </svg>
            <span class="nav-label">Workout</span>
            @if (isOnboarding) { <svg class="lock-icon" viewBox="0 0 24 24" fill="currentColor" width="10" height="10"><path d="M18 8h-1V6c0-2.76-2.24-5-5-5S7 3.24 7 6v2H6c-1.1 0-2 .9-2 2v10c0 1.1.9 2 2 2h12c1.1 0 2-.9 2-2V10c0-1.1-.9-2-2-2zM12 17c-1.1 0-2-.9-2-2s.9-2 2-2 2 .9 2 2-.9 2-2 2zM15.1 8H8.9V6c0-1.71 1.39-3.1 3.1-3.1s3.1 1.39 3.1 3.1v2z"/></svg> }
        </a>
        <a href="@(isOnboarding ? "/AI" : "/Week")" class="nav-item @(isOnboarding ? "locked" : "") @(ViewContext.HttpContext.Request.Path == "/Week" ? "active" : "")" data-path="/Week">
            <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <rect x="3" y="4" width="18" height="18" rx="2"></rect>
                <line x1="16" y1="2" x2="16" y2="6"></line>
                <line x1="8" y1="2" x2="8" y2="6"></line>
                <line x1="3" y1="10" x2="21" y2="10"></line>
            </svg>
            <span class="nav-label">Week</span>
            @if (isOnboarding) { <svg class="lock-icon" viewBox="0 0 24 24" fill="currentColor" width="10" height="10"><path d="M18 8h-1V6c0-2.76-2.24-5-5-5S7 3.24 7 6v2H6c-1.1 0-2 .9-2 2v10c0 1.1.9 2 2 2h12c1.1 0 2-.9 2-2V10c0-1.1-.9-2-2-2zM12 17c-1.1 0-2-.9-2-2s.9-2 2-2 2 .9 2 2-.9 2-2 2zM15.1 8H8.9V6c0-1.71 1.39-3.1 3.1-3.1s3.1 1.39 3.1 3.1v2z"/></svg> }
        </a>
        <a href="@(isOnboarding ? "/AI" : "/Progress")" class="nav-item @(isOnboarding ? "locked" : "") @(ViewContext.HttpContext.Request.Path == "/Progress" ? "active" : "")" data-path="/Progress">
            <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <polyline points="12 3 20 7.5 20 16.5 12 21 4 16.5 4 7.5 12 3"></polyline>
                <line x1="12" y1="12" x2="20" y2="7.5"></line>
                <line x1="12" y1="12" x2="12" y2="21"></line>
                <line x1="12" y1="12" x2="4" y2="7.5"></line>
            </svg>
            <span class="nav-label">Progress</span>
            @if (isOnboarding) { <svg class="lock-icon" viewBox="0 0 24 24" fill="currentColor" width="10" height="10"><path d="M18 8h-1V6c0-2.76-2.24-5-5-5S7 3.24 7 6v2H6c-1.1 0-2 .9-2 2v10c0 1.1.9 2 2 2h12c1.1 0 2-.9 2-2V10c0-1.1-.9-2-2-2zM12 17c-1.1 0-2-.9-2-2s.9-2 2-2 2 .9 2 2-.9 2-2 2zM15.1 8H8.9V6c0-1.71 1.39-3.1 3.1-3.1s3.1 1.39 3.1 3.1v2z"/></svg> }
        </a>
        <a href="@(isOnboarding ? "/AI" : "/Settings")" class="nav-item @(isOnboarding ? "locked" : "") @(ViewContext.HttpContext.Request.Path == "/Settings" ? "active" : "")" data-path="/Settings">
            <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <circle cx="12" cy="12" r="3"></circle>
                <path d="M12 1v6m0 6v6"></path>
                <path d="M4.22 4.22l4.24 4.24m5.08 5.08l4.24 4.24"></path>
                <path d="M1 12h6m6 0h6"></path>
                <path d="M4.22 19.78l4.24-4.24m5.08-5.08l4.24-4.24"></path>
                <path d="M19.78 19.78l-4.24-4.24m-5.08-5.08l-4.24-4.24"></path>
                <path d="M23 12h-6m-6 0H5"></path>
                <path d="M19.78 4.22l-4.24 4.24m-5.08 5.08l-4.24 4.24"></path>
            </svg>
            <span class="nav-label">Settings</span>
            @if (isOnboarding) { <svg class="lock-icon" viewBox="0 0 24 24" fill="currentColor" width="10" height="10"><path d="M18 8h-1V6c0-2.76-2.24-5-5-5S7 3.24 7 6v2H6c-1.1 0-2 .9-2 2v10c0 1.1.9 2 2 2h12c1.1 0 2-.9 2-2V10c0-1.1-.9-2-2-2zM12 17c-1.1 0-2-.9-2-2s.9-2 2-2 2 .9 2 2-.9 2-2 2zM15.1 8H8.9V6c0-1.71 1.39-3.1 3.1-3.1s3.1 1.39 3.1 3.1v2z"/></svg> }
        </a>
    </nav>

    <script>
        // Prevent bottom nav from covering content when keyboard appears
        window.addEventListener('resize', function() {
            if (window.innerHeight < 500) {
                document.body.classList.add('keyboard-open');
            } else {
                document.body.classList.remove('keyboard-open');
            }
        });

        // Auto-save session when navigating away from Today page
        document.querySelectorAll('.nav-item').forEach(link => {
            link.addEventListener('click', function(e) {
                // If we're on the Today page, auto-log session before navigating
                if (window.location.pathname === '/' || window.location.pathname === '/Index') {
                    navigator.sendBeacon('/api/logsession', new Blob([JSON.stringify({})], {type: 'application/json'}));
                }
            });
        });
    </script>
</body>
</html>
